rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Banners: solo usuarios autenticados pueden subir imágenes, todos pueden leer
    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Logo de la tienda: solo usuarios autenticados pueden subir, todos pueden leer
    match /logos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 3 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Productos: imágenes de productos, solo autenticados pueden subir
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // SEGURIDAD: Bloquear todo lo demás — no permitir subir archivos a rutas arbitrarias
    // Lectura pública para que las imágenes ya subidas sigan funcionando
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
